function formatDDasDMS(dd) {
    const sign = dd < 0 ? '-' : '';
    const absDD = Math.abs(dd);
    const deg = Math.floor(absDD);
    const minFloat = (absDD - deg) * 60;
    const min = Math.floor(minFloat);
    const sec = ((minFloat - min) * 60).toFixed(2);
    return `${sign}${deg}\u00B0${min}'${sec}"`;
}
